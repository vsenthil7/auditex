# Auditex -- Environment Variables
# Copy to .env and fill in values. NEVER commit .env.

ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=your_openai_api_key_here
GPT4O_MODEL=gpt-4o

DATABASE_URL=postgresql+asyncpg://auditex:auditex_dev_pw@localhost:5432/auditex
POSTGRES_USER=auditex
POSTGRES_PASSWORD=auditex_dev_pw
POSTGRES_DB=auditex

REDIS_URL=redis://localhost:6379/0

FOXMQ_BROKER_URL=mqtt://localhost:1883
VERTEX_NODE_URL=http://localhost:8545
VERTEX_PRIVATE_KEY=your_vertex_private_key_here

JWT_SECRET=change_in_production
API_KEY_SALT=change_in_production
ENVIRONMENT=development
LOG_LEVEL=INFO
API_PORT=8000
